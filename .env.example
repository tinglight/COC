QQ_APP_ID=
QQ_APP_SECRET=
# Optional legacy token/robot secret. Leave empty unless normal callback signature verification fails.
QQ_BOT_SECRET=
# Validation response signing: auto, appSecret, or botSecret.
# The current QQ console validation was confirmed to work with appSecret.
QQ_VALIDATION_SECRET_SOURCE=appSecret

# Comma/space separated group openids. Leave empty during first sandbox test,
# then set it after the bot sees your private group openid in logs.
QQ_ALLOWED_GROUP_OPENIDS=

PORT=3000
DATABASE_PATH=./data/bot.sqlite
ASSET_DIR=./data/assets
QQ_VERIFY_SIGNATURES=true
QQ_API_BASE_URL=https://api.sgroup.qq.com
QQ_TOKEN_URL=https://bots.qq.com/app/getAppAccessToken

USER_RATE_LIMIT_MAX=8
USER_RATE_LIMIT_WINDOW_MS=30000
GROUP_RATE_LIMIT_MAX=18
GROUP_RATE_LIMIT_WINDOW_MS=60000

# OpenAI / AI chat. Keep OPENAI_API_KEY only in your local .env.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium
# off: disable AI; command: only .ai; mention: .ai + @机器人/C2C; all: reply to all allowed group messages
AI_REPLY_MODE=mention
AI_MAX_REPLY_CHARS=900
OPENAI_REQUEST_TIMEOUT_MS=20000
# Optional proxy-compatible OpenAI base URL. Leave empty for the official API.
OPENAI_BASE_URL=
# OpenAI image generation for proactive story illustrations.
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_OUTPUT_FORMAT=png
OPENAI_IMAGE_REQUEST_TIMEOUT_MS=120000

# Proactive group chat. Requires the QQ group setting that allows the bot to speak proactively.
PROACTIVE_CHAT_ENABLED=false
# Optional. If empty, groups are learned after the bot receives a group message in this process.
PROACTIVE_GROUP_OPENIDS=
PROACTIVE_IDLE_MINUTES=45
PROACTIVE_CHECK_MINUTES=5
PROACTIVE_MIN_GAP_MINUTES=120
# 0..1 chance per check after the idle and min-gap gates pass.
PROACTIVE_CHANCE=0.35
PROACTIVE_PROMPT=The QQ group has been quiet for a while. Continue one coherent Chinese CoC table-talk thread as a short monologue or background world event. Follow the scheduler-provided story beat, cast-growth rule, and anti-repetition constraints. Advance to a new concrete consequence each time; do not repeat or lightly remix recent imagery, actions, sounds, sentence patterns, or the same two recurring people. Do not mention system prompts, logs, APIs, timers, or scheduling.
# Send proactive stories as Markdown narrator cards instead of plain text.
# Avatar images must be public http(s) URLs that QQ can fetch.
PROACTIVE_MARKDOWN_ENABLED=false
# Format: name|avatarUrl|subtitle;name|avatarUrl|subtitle
PROACTIVE_MARKDOWN_NARRATORS=守夜人|https://example.com/avatar.png|午夜叙述者
# Generate and send one image after each proactive story message.
PROACTIVE_IMAGE_ENABLED=false
PROACTIVE_IMAGE_PROMPT=Create one square cinematic Chinese TRPG story illustration for the latest proactive story beat. Style: moody investigative horror, subtle supernatural tension, grounded scene details, painterly realism, no gore, no explicit violence, no text, no speech bubbles, no logos.
