QQ_APP_ID=
QQ_APP_SECRET=
# 可选的旧版 Token/机器人密钥。除正常回调签名校验失败外，保持为空。
QQ_BOT_SECRET=
# 校验响应签名来源：auto、appSecret 或 botSecret。
# 当前 QQ 后台校验已确认可用 appSecret 通过。
QQ_VALIDATION_SECRET_SOURCE=appSecret

# 用逗号或空格分隔的群 openid。首次沙箱测试时可留空，
# 等 bot 在日志里看到你的私有群 openid 后再填写。
QQ_ALLOWED_GROUP_OPENIDS=

PORT=3000
ADMIN_PORT=8787
ADMIN_AUTO_RESTART=false
# `npm.cmd run desktop` 管理 bot 进程时使用的可选日志文件。
ADMIN_BOT_LOG_PATH=./logs/admin-console-bot.log
DATABASE_PATH=./data/bot.sqlite
ASSET_DIR=./data/assets
QQ_VERIFY_SIGNATURES=true
QQ_API_BASE_URL=https://api.sgroup.qq.com
QQ_TOKEN_URL=https://bots.qq.com/app/getAppAccessToken

USER_RATE_LIMIT_MAX=8
USER_RATE_LIMIT_WINDOW_MS=30000
GROUP_RATE_LIMIT_MAX=18
GROUP_RATE_LIMIT_WINDOW_MS=60000

# OpenAI / AI 聊天。OPENAI_API_KEY 只保存在本机 `.env`。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium
# off：关闭 AI；command：只响应 .ai；mention：响应 .ai + @机器人/C2C；all：全量接收群消息，但只选择性回复疑问、求助、点名搭话和少量适合插嘴的氛围消息
AI_REPLY_MODE=mention
AI_MAX_REPLY_CHARS=900
AI_CHAT_IMAGE_ENABLED=false
AI_CHAT_IMAGE_CHANCE=0.08
AI_CHAT_IMAGE_MIN_GAP_MINUTES=20
AI_CHAT_IMAGE_PROMPT=为最新一次群聊 AI 回复生成一张小尺寸正方形 QQ 反应表情包。使用原创可爱小鹰/猫头鹰桌边助手形象，主体清楚、表情夸张、背景极简；可带 2-12 字中文粗体短梗或群内公开语录，像聊天贴纸而不是完整插图，不要 UI、聊天气泡、Logo、水印或小字。
OPENAI_REQUEST_TIMEOUT_MS=20000
# 可选的 OpenAI 兼容代理 base URL。使用官方 API 时留空。
OPENAI_BASE_URL=
# 用于主动故事插图的 OpenAI 图片生成。
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_OUTPUT_FORMAT=png
OPENAI_IMAGE_REQUEST_TIMEOUT_MS=120000

# 主动群聊。需要 QQ 群设置允许 bot 主动发言。
# 这只是全局调度开关；每个群仍需要 KP 指令，
# 例如 .播报 on 或 .播报 模组 <module-id>，才会发送自动故事。
PROACTIVE_CHAT_ENABLED=false
# 可选。留空时，bot 会在本进程收到群消息后记住对应群。
PROACTIVE_GROUP_OPENIDS=
PROACTIVE_IDLE_MINUTES=45
PROACTIVE_CHECK_MINUTES=5
PROACTIVE_MIN_GAP_MINUTES=120
# 通过空闲和最小间隔门槛后，每次检查触发的概率，范围 0..1。
PROACTIVE_CHANCE=0.35
PROACTIVE_PROMPT=QQ群已经安静了一段时间。请用一段简短独白或背景世界事件，延续一条连贯的中文 CoC 桌边故事线。遵守调度器提供的故事节拍、人物成长规则和防重复约束。每次都推进到新的具体后果；不要重复或轻微改写近期意象、动作、声音、句式，或同一对反复出现的人物。不要提到系统提示词、日志、API、计时器或调度。
# 将主动故事作为 Markdown 叙述者名片发送，而不是纯文本。
# 头像必须是 QQ 能抓取的公网 http(s) URL。
PROACTIVE_MARKDOWN_ENABLED=false
# 格式：名字|头像URL|副标题;名字|头像URL|副标题
PROACTIVE_MARKDOWN_NARRATORS=守夜人|https://example.com/avatar.png|午夜叙述者
# 每条主动故事消息后生成并发送一张图片。
PROACTIVE_IMAGE_ENABLED=false
PROACTIVE_IMAGE_PROMPT=为最新主动故事节拍生成一张正方形中文 TRPG 电影感插图。风格：阴郁调查恐怖、微妙超自然张力、真实场景细节、绘画写实感、不要血腥、不要露骨暴力、不要文字、不要气泡、不要 Logo。
